---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { groupByCategory, localizedField } from '../../../content/queries';
import { currentLocale } from '../../../i18n/utils';
import { t } from '../../../i18n/strings';

const locale = currentLocale(Astro.url.pathname);

const faqEntries = await getCollection('faq');
const rendered = await Promise.all(
  faqEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return { category: entry.data.category, order: entry.data.order, data: entry.data, Content };
  }),
);
const groups = groupByCategory(rendered);
---

<BaseLayout title={t(locale, 'nav.faq')}>
  <h1>{t(locale, 'nav.faq')}</h1>
  {groups.map((group) => (
    <section class="faq-group" data-testid="faq-group">
      <h2>{t(locale, `faq.category.${group.category}`)}</h2>
      <dl>
        {group.items.map((item) => {
          const Answer = item.Content;
          return (
            <>
              <dt>{localizedField(item.data, 'question', locale)}</dt>
              <dd><Answer /></dd>
            </>
          );
        })}
      </dl>
    </section>
  ))}
</BaseLayout>
