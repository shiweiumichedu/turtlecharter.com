---
import { localizedField } from '../content/queries';
import { formatCny } from '../lib/pricing';
import { t } from '../i18n/strings';
import type { Locale } from '../i18n/utils';

interface Props {
  vehicle: Record<string, any>;
  locale: Locale;
}

const { vehicle, locale } = Astro.props;
const name = localizedField(vehicle, 'name', locale);
const features: string[] =
  locale === 'en' && vehicle.features_en?.length ? vehicle.features_en : vehicle.features_zh ?? [];
const rateNote = localizedField(vehicle, 'day_rate_note', locale);
const typeLabel = t(locale, `vehicles.type.${vehicle.type}`);
---

<article class="card vehicle-card" data-testid="vehicle-card">
  <h3>{name}</h3>
  <p class="meta">{typeLabel} · {vehicle.seats} {t(locale, 'vehicles.seats')}</p>
  {features.length > 0 && (
    <ul class="tags">{features.map((f) => <li>{f}</li>)}</ul>
  )}
  <p class="rate">
    <strong>{formatCny(vehicle.day_rate_cny)}</strong>
    <span>{t(locale, 'vehicles.perDay')}</span>
  </p>
  {rateNote && <p class="note">{rateNote}</p>}
</article>
