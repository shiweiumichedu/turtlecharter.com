---
import { localizedField } from '../content/queries';
import { localizedUrl, type Locale } from '../i18n/utils';

interface Props {
  driver: Record<string, any>;
  locale: Locale;
}

const { driver, locale } = Astro.props;
const name = localizedField(driver, 'name', locale);
const href = localizedUrl(`/drivers/${driver.slug}`, locale);
const specialties: string[] =
  locale === 'en' && driver.specialties_en?.length
    ? driver.specialties_en
    : driver.specialties_zh ?? [];
---

<a class="card driver-card" data-testid="driver-card" href={href}>
  <h3>{name}</h3>
  {driver.languages?.length > 0 && <p class="langs">{driver.languages.join(' · ')}</p>}
  {specialties.length > 0 && <p class="tags-inline">{specialties.join(' · ')}</p>}
</a>
