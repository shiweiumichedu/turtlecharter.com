---
import { localizedField } from '../content/queries';
import { t } from '../i18n/strings';
import { localizedUrl } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import { buildPrefilledMailto } from '../lib/inquiry';
import CopyInquiry from './CopyInquiry.astro';

interface Props {
  destination: Record<string, any>;
  locale: Locale;
}

const { destination, locale } = Astro.props;
const name = localizedField(destination, 'name', locale);
const blurb = localizedField(destination, 'blurb', locale);
const alt = localizedField(destination, 'alt', locale) || name;
const email = destination.email;
// With pinned spots we link to the on-site map page; otherwise fall back to the
// external Google Maps satellite link.
const hasSpots = (destination.spots?.length ?? 0) > 0;
const mapHref = hasSpots ? localizedUrl(`/destinations/${destination.slug}`, locale) : destination.mapUrl;
// Pre-fill the inquiry draft so travelers start from a template, not a blank email.
const emailSubject = t(locale, 'destinations.emailSubject').replace('{name}', name);
const emailBody = t(locale, 'destinations.emailBody').replace('{name}', name);
const emailHref = email ? buildPrefilledMailto(email, emailSubject, emailBody) : undefined;
---

<article class="card media-card destination-card" data-testid="destination-card">
  <img class="media-card__img" src={destination.image} alt={alt} loading="lazy" decoding="async" />
  {mapHref && (
    <a
      class="destination-map"
      data-testid="destination-map"
      href={mapHref}
      target={hasSpots ? undefined : '_blank'}
      rel={hasSpots ? undefined : 'noopener'}
    >
      {t(locale, 'destinations.mapLink')}
    </a>
  )}
  <div class="media-card__body">
    <h3>{name}</h3>
    {blurb && <p class="blurb">{blurb}</p>}
    {email && (
      <p class="destination-email" data-testid="destination-email">
        <span class="destination-email__label">{t(locale, 'destinations.emailInvite')}</span>
        <a href={emailHref} title={t(locale, 'destinations.emailHint')}>{email}</a>
        <CopyInquiry email={email} subject={emailSubject} body={emailBody} locale={locale} />
      </p>
    )}
  </div>
</article>

<style>
  .destination-map {
    display: block;
    padding: 0.5rem 1rem 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-brand-dark, #0a5c4c);
    text-decoration: none;
  }
  .destination-map:hover {
    text-decoration: underline;
  }
  .destination-email {
    margin-top: 0.75rem;
    font-size: 0.9rem;
    line-height: 1.4;
  }
  .destination-email__label {
    display: block;
    color: var(--color-muted, #666);
  }
  .destination-email a {
    font-weight: 600;
    word-break: break-all;
  }
</style>
